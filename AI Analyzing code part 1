# ⑤ 크롤링 유틸
# ══════════════════════════════════════════════
def _fetch_bytes(url: str):
    try:
        req = urllib.request.Request(
            url,
            headers={"User-Agent": "Mozilla/5.0 (compatible; CareerBot/1.0)"},
        )
        with urllib.request.urlopen(req, timeout=15) as resp:
            return resp.read()
    except Exception as e:
        print(f"    ⚠ 다운로드 실패 [{url}]: {e}")
        return None


def _parse_pdf_bytes(data: bytes) -> str:
    try:
        reader = pypdf.PdfReader(io.BytesIO(data))
        pages = [page.extract_text() or "" for page in reader.pages]
        text = "\n".join(pages)
        print(f"    ✔ PDF 파싱 완료 ({len(reader.pages)}페이지, {len(text)}자)")
        return text
    except Exception as e:
        print(f"    ⚠ PDF 파싱 오류: {e}")
        return ""


def _parse_html_bytes(data: bytes, url: str):
    try:
        html = data.decode("utf-8")
    except UnicodeDecodeError:
        html = data.decode("euc-kr", errors="replace")
    parser = _TextExtractor(base_url=url)
    parser.feed(html)
    return parser.get_text(), parser.get_links(), html


def _same_origin(url_a: str, url_b: str) -> bool:
    return urllib.parse.urlparse(url_a).netloc == urllib.parse.urlparse(url_b).netloc


def fetch_url(base_url: str) -> str:
    print(f"  🌐 크롤링 시작: {base_url}")
    collected = []
    visited = set()

    raw = _fetch_bytes(base_url)
    if raw is None:
        return ""

    if base_url.lower().endswith(".pdf") or (raw and raw[:4] == b"%PDF"):
        text = _parse_pdf_bytes(raw)
        if text:
            collected.append(f"[PDF: {base_url}]\n{text}")
        result = "\n\n".join(collected)
        print(f"  ✔ 최종 수집 텍스트: {len(result)}자")
        return result

    html_text, links, raw_html = _parse_html_bytes(raw, base_url)
    visited.add(base_url)

    spa_detected = _is_spa(raw_html)
    if html_text.strip():
        collected.append(f"[메인 페이지]\n{html_text}")
        print(f"    → 메인 HTML 텍스트: {len(html_text)}자")

    if spa_detected:
        print("    ⚡ SPA 감지 — 하위 페이지·PDF 자동 탐색 시작")
    else:
        print("    ℹ 일반 HTML — 링크 내 PDF·서브페이지 탐색")

    to_visit = []
    seen = set()
    for lnk in links:
        clean = lnk.split("#")[0]
        if (
            clean
            and clean not in seen
            and clean not in visited
            and _same_origin(base_url, clean)
            and not clean.startswith("mailto:")
        ):
            seen.add(clean)
            to_visit.append(clean)

    print(f"    → 같은 도메인 링크 {len(to_visit)}개 발견")

    for lnk in to_visit[:20]:
        if lnk in visited:
            continue
        visited.add(lnk)

        sub_raw = _fetch_bytes(lnk)
        if sub_raw is None:
            continue

        is_pdf = lnk.lower().endswith(".pdf") or sub_raw[:4] == b"%PDF"
        if is_pdf:
            print(f"    📄 PDF 발견: {lnk}")
            pdf_text = _parse_pdf_bytes(sub_raw)
            if pdf_text.strip():
                collected.append(f"[PDF: {lnk}]\n{pdf_text}")
        else:
            sub_text, sub_links, _ = _parse_html_bytes(sub_raw, lnk)
            if sub_text.strip():
                print(f"    📃 서브페이지: {lnk} ({len(sub_text)}자)")
                collected.append(f"[서브페이지: {lnk}]\n{sub_text}")
            for sl in sub_links:
                sl_clean = sl.split("#")[0]
                if (
                    sl_clean.lower().endswith(".pdf")
                    and sl_clean not in visited
                    and _same_origin(base_url, sl_clean)
                ):
                    visited.add(sl_clean)
                    print(f"    📄 PDF 발견 (서브): {sl_clean}")
                    pdf_raw = _fetch_bytes(sl_clean)
                    if pdf_raw:
                        pdf_text = _parse_pdf_bytes(pdf_raw)
                        if pdf_text.strip():
                            collected.append(f"[PDF: {sl_clean}]\n{pdf_text}")

    result = "\n\n".join(collected)
    print(f"\n  ✔ 최종 수집 텍스트: {len(result)}자 (소스 {len(collected)}개)")
    return result


