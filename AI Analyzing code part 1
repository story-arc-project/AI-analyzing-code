def analyze_career_pro(user_text: str, ref_date: date) -> dict:
    system_prompt = build_system_prompt(ref_date)
    prompt = (
        f"다음 사용자 데이터를 바탕으로 커리어 분석을 수행하고, "
        f"{ref_date.strftime('%Y-%m-%d')} 이후 마감인 유효한 채용공고를 "
        f"Google Search로 검색하여 추천하세요:\n\n{user_text}"
    )

    raw_text = ""
    try:
        # ✅ 새 SDK: client.models.generate_content + google_search 도구
        response = client.models.generate_content(
            model=_ANALYSIS_MODEL,
            contents=prompt,
            config=types.GenerateContentConfig(
                system_instruction=system_prompt,
                tools=[types.Tool(google_search=types.GoogleSearch())],
                temperature=0.3,
            ),
        )
        raw_text = response.text.strip()
        cleaned = clean_json_response(raw_text)
        return json.loads(cleaned)

    except json.JSONDecodeError as e:
        return {
            "status": "error",
            "message": f"JSON 파싱 실패 (위치: 줄 {e.lineno}, 컬럼 {e.colno}) — {e.msg}",
            "raw_response": raw_text or "응답 없음",   # 전체 저장 (출력은 500자 제한)
        }
    except Exception as e:
        # google_search 도구 미지원 환경 fallback
        try:
            response = client.models.generate_content(
                model=_ANALYSIS_MODEL,
                contents=prompt,
                config=types.GenerateContentConfig(
                    system_instruction=system_prompt,
                    temperature=0.3,
                ),
            )
            raw_text = response.text.strip()
            cleaned = clean_json_response(raw_text)
            return json.loads(cleaned)
        except Exception as e2:
            return {"status": "error", "message": str(e2)}


