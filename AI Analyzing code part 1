def get_reference_date() -> date:
    today_str = datetime.now().strftime("%Y-%m-%d")
    print(f"\n[채용공고 마감일 기준]")
    print(f"  입력한 날짜 이후에 마감되는 공고만 유효한 공고로 표시합니다.")
    raw = input(f"  기준 날짜 입력 (YYYY-MM-DD, 기본값: 오늘 {today_str}): ").strip()

    if not raw:
        ref = date.today()
        print(f"  → 오늘({today_str}) 기준으로 검색합니다.")
        return ref

    try:
        ref = datetime.strptime(raw, "%Y-%m-%d").date()
        print(f"  → {ref.strftime('%Y-%m-%d')} 기준으로 검색합니다.")
        return ref
    except ValueError:
        print("  ⚠ 날짜 형식이 잘못되었습니다. 오늘 날짜로 대체합니다.")
        return date.today()


