# ④ HTML 파서
# ══════════════════════════════════════════════
class _TextExtractor(HTMLParser):
    SKIP_TAGS = {"script", "style", "noscript", "meta", "link", "head"}

    def __init__(self, base_url: str = ""):
        super().__init__()
        self._skip_depth = 0
        self._parts: list = []
        self._links: list = []
        self._base_url = base_url

    def handle_starttag(self, tag, attrs):
        if tag.lower() in self.SKIP_TAGS:
            self._skip_depth += 1
        if tag.lower() == "a":
            href = dict(attrs).get("href", "")
            if href:
                full = urllib.parse.urljoin(self._base_url, href)
                self._links.append(full)

    def handle_endtag(self, tag):
        if tag.lower() in self.SKIP_TAGS and self._skip_depth > 0:
            self._skip_depth -= 1

    def handle_data(self, data):
        if self._skip_depth == 0:
            s = data.strip()
            if s:
                self._parts.append(s)

    def get_text(self) -> str:
        return "\n".join(self._parts)

    def get_links(self) -> list:
        return self._links


def _is_spa(html: str) -> bool:
    visible_text_len = len(re.sub(r"<[^>]+>", " ", html).strip())
    script_count = html.lower().count("<script")
    return visible_text_len < 2000 and script_count >= 2


