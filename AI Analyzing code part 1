# JSON 정제
# ──────────────────────────────────────────────
def clean_json_response(raw_text: str) -> str:
    """
    모델 응답에서 순수 JSON 객체만 추출합니다.
    처리 패턴:
      1) ```json ... ``` 또는 ``` ... ``` 코드블록
      2) 앞뒤 설명 텍스트 + { ... }
      3) google_search grounding 메타데이터 혼입
      4) JSON 뒤 부연 설명
    """
    raw_text = raw_text.strip()

    # 패턴 1: 마크다운 코드블록 안의 JSON 우선 추출
    m = re.search(r"```(?:json)?\s*\n?(.*?)\n?\s*```", raw_text, re.DOTALL | re.IGNORECASE)
    if m:
        return m.group(1).strip()

    # 패턴 2: 코드블록 없으면 { } 범위 직접 추출
    start = raw_text.find("{")
    end   = raw_text.rfind("}")
    if start != -1 and end != -1 and end > start:
        return raw_text[start:end + 1].strip()

    # 패턴 3: 그래도 없으면 원문 그대로 반환 (오류 메시지 보존)
    return raw_text


