def get_user_input(mode_label: str = "") -> str:
    print(f"\n[입력 방식{' — ' + mode_label if mode_label else ''}]")
    print("  1: URL 크롤링  (SPA·PDF 자동 탐색)")
    print("  2: 파일 경로   (.txt / .pdf 지원)")
    print("  3: 텍스트 직접 입력")
    mode = input("선택 (기본값: 3): ").strip() or "3"

    if mode == "1":
        url = input("URL을 입력하세요: ").strip()
        if not url.startswith("http"):
            url = "https://" + url
        content = fetch_url(url)
        if not content:
            print("  ⚠ 크롤링 실패 — 텍스트를 직접 입력해 주세요.")
            mode = "3"
        else:
            return content

    if mode == "2":
        path = input("파일 경로를 입력하세요: ").strip()
        content = read_file(path)
        if not content:
            print("  ⚠ 파일 읽기 실패 — 텍스트를 직접 입력해 주세요.")
            mode = "3"
        else:
            return content

    print("\n입력을 마치려면 빈 줄에서 'END'를 입력하세요.\n")
    lines = []
    while True:
        line = input()
        if line.strip().upper() == "END":
            break
        lines.append(line)
    return "\n".join(lines)


