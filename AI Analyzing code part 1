# ⑪ 채용공고 날짜 유효성 검증 (종합 분석 전용)
# ══════════════════════════════════════════════
def filter_valid_jobs(jobs: list, ref_date: date) -> tuple:
    valid, expired = [], []
    for job in jobs:
        deadline_str = job.get("deadline", "")
        if not deadline_str or deadline_str in ("상시채용", "없음", "미정", "-"):
            job["is_valid"] = True
            valid.append(job)
            continue
        try:
            deadline = datetime.strptime(deadline_str, "%Y-%m-%d").date()
            if deadline >= ref_date:
                job["is_valid"] = True
                valid.append(job)
            else:
                job["is_valid"] = False
                expired.append(job)
        except ValueError:
            job["is_valid"] = True
            valid.append(job)
    return valid, expired


