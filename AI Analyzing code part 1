# ──────────────────────────────────────────────
# ✅ 채용공고 날짜 유효성 검증 (클라이언트 2차 검증)
# ──────────────────────────────────────────────
def filter_valid_jobs(jobs: list, ref_date: date) -> tuple:
    """
    모델이 반환한 공고를 날짜 기준으로 한 번 더 검증합니다.
    반환: (유효 공고 리스트, 만료 공고 리스트)
    """
    valid, expired = [], []
    for job in jobs:
        deadline_str = job.get("deadline", "")
        # '상시채용' 또는 날짜 파싱 불가 → 유효로 간주
        if not deadline_str or deadline_str in ("상시채용", "없음", "미정", "-"):
            job["is_valid"] = True
            valid.append(job)
            continue
        try:
            deadline = datetime.strptime(deadline_str, "%Y-%m-%d").date()
            if deadline >= ref_date:
                job["is_valid"] = True
                valid.append(job)
            else:
                job["is_valid"] = False
                expired.append(job)
        except ValueError:
            # 날짜 형식 불일치 → 유효로 간주
            job["is_valid"] = True
            valid.append(job)
    return valid, expired


