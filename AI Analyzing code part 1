        print(f"\n• [{badge}] {job.get('company', '-')} | {job.get('role', '-')}")
        print(f"  - 매칭 이유: {job.get('why_match', '-')}")
        print(f"  - 공고 확인: {job.get('url', '-')}")

    if expired_jobs:
        print(f"\n" + "-" * 20 + " [⚠ 마감된 공고 — 참고용] " + "-" * 20)
        for job in expired_jobs:
            print(f"\n• [❌ 마감 {job.get('deadline', '-')}] {job.get('company', '-')} | {job.get('role', '-')}")
            print(f"  - 공고 확인: {job.get('url', '-')}")

    warning = result.get("missing_info_warning")
    if warning:
        print(f"\n⚠ 참고: {warning}")


